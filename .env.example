# ---- Supform environment (copy to .env) ----

# App
SUPFORM_ENV=development
SUPFORM_SECRET_KEY=change-me-to-a-long-random-string
SUPFORM_DEBUG=true

# API
SUPFORM_API_HOST=0.0.0.0
SUPFORM_API_PORT=8000
SUPFORM_CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL — JSONB is used for flexible form schemas)
SUPFORM_DATABASE_URL=postgresql+asyncpg://supform:supform@localhost:5432/supform

# Redis / Celery (async export & import jobs)
SUPFORM_REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
SUPFORM_JWT_ALGORITHM=HS256
SUPFORM_ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPFORM_REFRESH_TOKEN_EXPIRE_DAYS=14

# AI form generation (optional — off until a key is set)
# SUPFORM_AI_API_KEY=sk-ant-...
SUPFORM_AI_MODEL=claude-sonnet-4-6
SUPFORM_AI_BASE_URL=https://api.anthropic.com/v1/messages

# Abuse protection
SUPFORM_RATE_LIMIT_ENABLED=true          # per-IP throttle on login/signup/submit
SUPFORM_WEBHOOK_BLOCK_PRIVATE_IPS=true   # SSRF guard: refuse webhook URLs to internal hosts

# Email (verification & password reset). Links point at SUPFORM_APP_BASE_URL.
SUPFORM_APP_BASE_URL=http://localhost:5173
SUPFORM_EMAIL_BACKEND=console            # console (logs) | smtp | memory (tests)
SUPFORM_EMAIL_FROM=Supform <no-reply@supform.local>
# SMTP (used when SUPFORM_EMAIL_BACKEND=smtp)
SUPFORM_SMTP_HOST=localhost
SUPFORM_SMTP_PORT=587
SUPFORM_SMTP_USE_TLS=true
# SUPFORM_SMTP_USERNAME=
# SUPFORM_SMTP_PASSWORD=

# Object storage for media/attachments
SUPFORM_STORAGE_BACKEND=local            # local | s3
SUPFORM_STORAGE_LOCAL_PATH=./media
SUPFORM_MAX_UPLOAD_MB=10
# S3 / S3-compatible (used when SUPFORM_STORAGE_BACKEND=s3; pip install '.[s3]')
# SUPFORM_S3_BUCKET=
# SUPFORM_S3_REGION=us-east-1
# SUPFORM_S3_ENDPOINT_URL=                # set for MinIO / non-AWS, leave blank for AWS
# SUPFORM_S3_ACCESS_KEY_ID=
# SUPFORM_S3_SECRET_ACCESS_KEY=
# SUPFORM_S3_PREFIX=                       # optional key prefix within the bucket

# Frontend
VITE_API_BASE_URL=http://localhost:8000
