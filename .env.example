# ---- Supform environment (copy to .env) ----

# App
SUPFORM_ENV=development
SUPFORM_SECRET_KEY=change-me-to-a-long-random-string
SUPFORM_DEBUG=true

# API
SUPFORM_API_HOST=0.0.0.0
SUPFORM_API_PORT=8000
SUPFORM_CORS_ORIGINS=http://localhost:5173

# Database (PostgreSQL — JSONB is used for flexible form schemas)
SUPFORM_DATABASE_URL=postgresql+asyncpg://supform:supform@localhost:5432/supform

# Redis / Celery (async export & import jobs)
SUPFORM_REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
SUPFORM_JWT_ALGORITHM=HS256
SUPFORM_ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPFORM_REFRESH_TOKEN_EXPIRE_DAYS=14

# Object storage for media/attachments (S3-compatible; optional in dev)
SUPFORM_STORAGE_BACKEND=local
SUPFORM_STORAGE_LOCAL_PATH=./media
# SUPFORM_S3_ENDPOINT=
# SUPFORM_S3_BUCKET=
# SUPFORM_S3_ACCESS_KEY=
# SUPFORM_S3_SECRET_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
