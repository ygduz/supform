{
  "schemaVersion": "1.0",
  "name": "household_survey",
  "title": "Household survey",
  "description": "Demonstrates conditional logic, calculations, matrices and repeating groups.",
  "defaultLanguage": "en",
  "languages": ["en", "fr"],
  "theme": { "preset": "supform-light", "primaryColor": "#2563eb" },
  "settings": { "displayMode": "paged", "showProgressBar": true },
  "pages": [
    {
      "name": "respondent",
      "title": { "en": "About you", "fr": "À propos de vous" },
      "elements": [
        {
          "type": "single_choice",
          "name": "region",
          "label": { "en": "Region", "fr": "Région" },
          "required": true,
          "options": [
            { "value": "north", "label": { "en": "North", "fr": "Nord" } },
            { "value": "south", "label": { "en": "South", "fr": "Sud" } }
          ]
        },
        {
          "type": "integer",
          "name": "age",
          "label": "Your age",
          "required": true,
          "validation": { "min": 0, "max": 120, "message": "Enter an age between 0 and 120." }
        },
        {
          "type": "single_choice",
          "name": "is_head",
          "label": "Are you the head of household?",
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ],
          "visibleIf": "age >= 18"
        }
      ]
    },
    {
      "name": "household",
      "title": "Household members",
      "elements": [
        {
          "type": "integer",
          "name": "member_count",
          "label": "How many people live in the household?",
          "required": true,
          "validation": { "min": 1, "max": 30 }
        },
        {
          "type": "repeat",
          "name": "members",
          "label": "Tell us about each member",
          "repeat": { "min": 1, "max": 30, "addButtonText": "Add a person" },
          "elements": [
            { "type": "text", "name": "member_name", "label": "Name", "required": true },
            {
              "type": "single_choice",
              "name": "relationship",
              "label": "Relationship to head",
              "options": [
                { "value": "spouse", "label": "Spouse" },
                { "value": "child", "label": "Child" },
                { "value": "other", "label": "Other" }
              ]
            }
          ]
        },
        {
          "type": "matrix",
          "name": "assets",
          "label": "Which assets does the household own?",
          "rows": [
            { "value": "radio", "label": "Radio" },
            { "value": "bicycle", "label": "Bicycle" },
            { "value": "phone", "label": "Mobile phone" }
          ],
          "columns": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ]
        }
      ]
    },
    {
      "name": "summary",
      "title": "Summary",
      "elements": [
        {
          "type": "calculated",
          "name": "avg_unused",
          "label": "Average members per page (demo calc)",
          "calculate": "member_count / 1",
          "readOnly": true
        },
        {
          "type": "note",
          "name": "thanks_note",
          "label": "Thank you for completing the survey!"
        }
      ]
    }
  ]
}
