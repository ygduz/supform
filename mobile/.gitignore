# Environment — contains your backend URL, not a secret but personal to each dev
.env

# Node
node_modules/

# Capacitor native project artifacts (generated by `cap add ios/android`)
# Commit ios/ and android/ if you want reproducible native builds in CI.
# Ignore only the generated/downloaded artifacts inside them:
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
android/.gradle/
android/app/build/
android/build/

# Xcode user data
*.xcuserstate
